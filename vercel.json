{
  "installCommand": "npm install",
  "buildCommand": "npm --workspace frontend run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": [
        "backend/**",
        "node_modules/.prisma/**",
        "node_modules/@prisma/**"
      ]
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "hbrealstate.com" }],
      "destination": "https://www.hbrealstate.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/index.js" },
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
